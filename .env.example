# Copy this file to .env and set the paths for your machine.

# Path to your unpacked Ableton Extensions SDK (the folder containing
# package-archives/). Used by `npm run setup` to vendor the SDK tarballs.
ABLETON_SDK_PATH=/path/to/extensions-sdk-1.0.0-beta.0

# Path to the Ableton Live app whose Extension Host to launch (.app on macOS).
# Used by `extensions-cli run` (npm start). For live Developer-Mode iteration,
# point this at your Beta, e.g. /Applications/Ableton Live 12 Beta.app
EXTENSION_HOST_PATH=/Applications/Ableton Live 12 Beta.app
