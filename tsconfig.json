{
  // Bundler resolution matches our toolchain (esbuild build + Vitest), so modules
  // can use extensionless relative imports. `tsc --noEmit` (in `npm run typecheck`)
  // type-checks everything under src/, including the colocated *.test.ts files;
  // esbuild bundles only what src/extension.ts imports, so tests never reach dist.
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
